FROM public.ecr.aws/docker/library/node:current-alpine AS build-stage

# set working directory
WORKDIR /app

# add `/app/node_modules/.bin` to $PATH
ENV PATH=/app/node_modules/.bin:$PATH

# install app dependencies
COPY app/package.json .
COPY app/package-lock.json .
 
RUN rm -f package-lock.json && npm install --no-package-lock

COPY ./app /app/
RUN npm run build 

FROM public.ecr.aws/docker/library/nginx:stable-alpine

ENV APP_HOME=/launchpad
ENV APP_USER=launchpad
ENV APP_GROUP=launchpad     
ENV STATIC_FILES=/usr/share/nginx/html

# explicitly set user/group IDs
RUN addgroup -g 10000 -S $APP_GROUP && \
 adduser -u 10000 -S -G $APP_GROUP $APP_USER

RUN mkdir -p ${APP_HOME} /cache/nginx

RUN chmod -R u+x ${APP_HOME} && \
chown -R ${APP_USER} ${APP_HOME}

WORKDIR $APP_HOME
## Remove default nginx index page
RUN rm -rf /usr/share/nginx/html/*

# Copy from build stage 
COPY --from=build-stage /app/build/ ${STATIC_FILES}
COPY app/nginx.conf /etc/nginx/nginx.conf
COPY bootstrapClientEnvironment.sh .

# Set file and folder permissions for user.

RUN     chmod u+x ./bootstrapClientEnvironment.sh && \
        chmod -R u+x ${APP_HOME} && \
        chmod -R u+x ${STATIC_FILES} && \
        chown -R ${APP_USER}:${APP_GROUP} ${APP_HOME} && \
        chown -R ${APP_USER}:${APP_GROUP} ${STATIC_FILES} && \
        chown -R ${APP_USER}:${APP_GROUP} /var/cache/nginx && \
        chown -R ${APP_USER}:${APP_GROUP} /var/log/nginx && \
        chown -R ${APP_USER}:${APP_GROUP} /etc/nginx/conf.d && \
        touch /tmp/nginx.pid && \
        chown -R ${APP_USER}:${APP_GROUP} /tmp/nginx.pid

# switch to unpriviledged user
USER ${APP_USER}

EXPOSE 8090

ENTRYPOINT [ "./bootstrapClientEnvironment.sh" ]
CMD ["nginx", "-g", "daemon off;"]